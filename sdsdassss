    local fl=cInst(Instance.new("Frame"),bg,{BackgroundColor3=Color3.fromRGB(162,137,245),BorderSizePixel=0,Size=UDim2.new(math.clamp((st-mn)/(mx-mn),0,1),0,1,0),ZIndex=14})
