    bg.InputBegan:Connect(function(i) if i.UserInputType.Name=="MouseButton1" or i.UserInputType.Name=="Touch" then drag=true;up(i) end end)
    UIS.InputChanged:Connect(function(i) if drag and (i.UserInputType.Name=="MouseMovement" or i.UserInputType.Name=="Touch") then up(i) end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType.Name=="MouseButton1" or i.UserInputType.Name=="Touch" then drag=false end end)
end

